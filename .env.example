# ===== binance-square-engine — environment variables =====
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ----- Identity / branding -----
ACCOUNT_HANDLE=KinzoTech
ACCOUNT_DISPLAY_NAME=Kinzo Tech
SQUARE_UID=                              # your Binance Square UID (optional, used for analytics)
REFERENCE_SQUARE_UID=BGzelAbjfOwj01wOvfmP5g  # momomomo7171 — reference feed

# ----- LLM -----
GEMINI_API_KEY=                          # https://aistudio.google.com/apikey
LLM_PROVIDER=gemini                      # gemini | openai | mock
LLM_MODEL=gemini-1.5-flash               # gemini-1.5-flash | gemini-1.5-pro

# ----- Image hosting (for image URLs in posts) -----
IMGBB_API_KEY=                           # https://api.imgbb.com (free)

# ----- Binance Square publishing -----
# Option A: Official OpenAPI (preferred)
X_SQUARE_OPENAPI_KEY=                    # if you have one; leave blank to fall back to browser
# Option B: Browser automation fallback (Playwright)
BINANCE_COOKIES_PATH=./data/runtime/binance_cookies.json
PUBLISH_MODE=hybrid                      # api | browser | hybrid | dry_run

# ----- Safety rails -----
MAX_POSTS_PER_DAY=40
MAX_POSTS_PER_HOUR=4
MIN_GAP_SAME_TICKER_HOURS=4
PAUSE_IF_N_LOW_VIEWS=3
LOW_VIEWS_THRESHOLD=500
PAUSE_HOURS=1

# ----- Database -----
DATABASE_URL=sqlite+aiosqlite:///./data/runtime/engine.db

# ----- Scheduler -----
SCHEDULER_TIMEZONE=UTC
DAILY_SCHEDULE_FILE=./playbooks/daily_schedule.yaml
BURST_TRIGGERS_FILE=./playbooks/burst_triggers.yaml

# ----- Logging -----
LOG_LEVEL=INFO
LOG_FORMAT=console                       # console | json

# ----- Dashboard (FastAPI) -----
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_ENABLED=true

# ----- News feeds (optional) -----
NEWS_RSS_URLS=https://cointelegraph.com/rss,https://www.coindesk.com/arc/outboundfeeds/rss
